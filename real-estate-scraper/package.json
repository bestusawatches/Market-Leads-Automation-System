  "devDependencies": {
    "prisma": "latest",
    "typescript": "^5.1.6",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "@types/node": "^18.0.0",
    "@types/winston": "^2.4.4"
  }
