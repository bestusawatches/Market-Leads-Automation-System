generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Listing {
  id         Int      @id @default(autoincrement())
  source     String
  externalId String
  title      String?
  price      Int?
  url        String
  raw        Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([source, externalId])
}
