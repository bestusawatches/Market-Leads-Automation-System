// prisma/schema.prisma
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider          = "postgresql"
  url            = env("DATABASE_URL")
  shadowDatabaseUrl = env("DEV_SHADOW_DATABASE_URL")
}

model Listing {
  id          String   @id @default(cuid())

  // ── identity (used for deduplication) ───────────────────────────────────
  url         String   @unique
  source      String   // "craigslist" | "zillow" | "realtor" | etc.

  // ── core fields ──────────────────────────────────────────────────────────
  title       String?
  price       Int?
  address     String?
  location    String?
  propertyType String?  // "single_family" | "multi_family" | "duplex"

  // ── property details ─────────────────────────────────────────────────────
  bedrooms    Int?
  bathrooms   Float?
  squareFeet  Int?
  description String?
  postedDate  DateTime?

  // ── enrichment (filled by enrichment pipeline) ───────────────────────────
  zestimate        Int?
  realtorEstimate  Int?
  redfinEstimate   Int?

  // ── underwriting ─────────────────────────────────────────────────────────
  // "good_deal" | "average_deal" | "low_potential" | null (not yet scored)
  dealScore   String?
  equityEstimate Int?   // zestimate - price

  // ── owner contact (from third-party enrichment) ──────────────────────────
  ownerName   String?
  ownerPhone  String?

  // ── meta ──────────────────────────────────────────────────────────────────
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastSeenAt  DateTime @default(now())

  @@index([source])
  @@index([price])
  @@index([location])
  @@index([dealScore])
}
