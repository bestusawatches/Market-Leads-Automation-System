# ── Browser & Proxy ──────────────────────────────────────────────────────────
# Proxy URL for web scraping (optional — set to empty string to disable)
# Format: http://user:pass@host:port
# PROXY_URL=http://user:pass@proxy.example.com:6543

# ── Scraping Limits ───────────────────────────────────────────────────────────
# MAX_PAGES=5
# MAX_LISTINGS=20
# REQUEST_DELAY_MS=2000

# ── Crexi Scraper ─────────────────────────────────────────────────────────────
# Optional: Override Crexi search URLs (comma-separated)
# If not set, defaults to Ohio + Wisconsin multifamily searches
# CREXI_SEARCH_URLS=https://www.crexi.com/properties/OH/Multifamily,https://www.crexi.com/properties/WI/Milwaukee

# ── LoopNet Scraper ───────────────────────────────────────────────────────────
# Optional: Override LoopNet search URLs (comma-separated)
# If not set, defaults to Ohio + Wisconsin multifamily searches
# LOOPNET_SEARCH_URLS=https://www.loopnet.com/search/multifamily-properties/oh/for-sale/,https://www.loopnet.com/search/multifamily-properties/milwaukee-wi/for-sale/
# Maximum pages per LoopNet search URL (default: 3)
# LOOPNET_MAX_PAGES=3

# ── Database ──────────────────────────────────────────────────────────────────
# Prisma database connection string (if using external database)
# DATABASE_URL=postgresql://user:password@localhost:5432/real_estate_leads

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=info

