  price       Int?
  address     String?
  location    String?
  propertyType String?
  postedDate  DateTime?
  description String?

  bedrooms    Int?
  bathrooms   Float?
  squareFeet  Int?

  zestimate   Int?

  // ── Meta ────────────────────────────────────────────────
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastSeenAt  DateTime @default(now())

  @@index([price])
  @@index([location])
}

