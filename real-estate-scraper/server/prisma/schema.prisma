// prisma/schema.prisma
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider          = "postgresql"
  url            = env("DATABASE_URL")
  // shadowDatabaseUrl = env("DEV_SHADOW_DATABASE_URL")
}

model Property {
  id                  String   @id @default(cuid())

  // 🔥 Canonical identity
  normalizedAddress   String   @unique
  address             String?
  url                 String?  // optional link to listing (populated during enrichment phase)

  city                String?
  state               String?
  zip                 String?

  latitude            Float?
  longitude           Float?

  // Relations
  listings            Listing[]
  estimates           Estimate[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([city, state])
}

model Listing {
  id          String   @id @default(cuid())

  // ── Identity ─────────────────────────────────────────────
  url         String   @unique
  source      String

  // 🔥 Optional: link to property (populated during enrichment phase)
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])

  // ── Raw scraped data ─────────────────────────────────────
  title        String?
  price        Int?
  rawAddress   String?   // renamed (important)
  location     String?
  propertyType String?
  postedDate   DateTime?
  description  String?

  bedrooms     Int?
  bathrooms    Float?
  squareFeet   Int?

  ownerName    String?
  ownerPhone   String?

  // ❌ REMOVE THESE (they move to Estimate table)
  // zestimate
  // realtorEstimate
  // redfinEstimate
  // propwireEstimate

  // ── Underwriting ─────────────────────────────────────────
  dealScore      String?
  equityEstimate Int?

  // ── Meta ────────────────────────────────────────────────
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  @@index([source])
  @@index([price])
  @@index([location])
  @@index([dealScore])
  @@index([propertyType])
  @@index([ownerPhone])
  @@index([propertyId])
}

model Estimate {
  id          String   @id @default(cuid())

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id])

  source      String   // "zillow" | "redfin" | "realtor" | "propwire"
  value       Int

  sourceListingId String?  // ID of ZillowListing/RedfinListing/RealtorListing/PropwireListing

  fetchedAt   DateTime @default(now())

  @@unique([propertyId, source]) // 🔥 prevents duplicates
  @@index([source])
}

model ZillowListing {
  id          String   @id @default(cuid())

  // ── Identity ─────────────────────────────────────────────
  url         String   @unique

  // ── Raw scraped data ─────────────────────────────────────
  title       String?
  price       Int?
  address     String?
  location    String?
  propertyType String?
  postedDate  DateTime?
  description String?

  bedrooms    Int?
  bathrooms   Float?
  squareFeet  Int?

  zestimate   Int?

  // ── Meta ────────────────────────────────────────────────
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastSeenAt  DateTime @default(now())

  @@index([price])
  @@index([location])
}

