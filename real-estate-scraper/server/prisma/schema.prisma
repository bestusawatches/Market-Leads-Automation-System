model SavedFilter {
  id           String   @id @default(cuid())
 
  // ── Filter criteria (simplified to match config.filter) ──────────────────
  minPrice     Int?
  maxPrice     Int?
  allowedPropertyTypes String[] // e.g. ["single_family","multi_family","duplex"]
  keywords     String[]         // include terms
  propertyTypeTokens String[]   // tokens used to map property types
  allowedLocations String[]     // e.g. ["ohio","cleveland","wi"]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

}
