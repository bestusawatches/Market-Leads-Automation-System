// prisma/schema.prisma
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider          = "postgresql"
  url            = env("DATABASE_URL")
  // shadowDatabaseUrl = env("DEV_SHADOW_DATABASE_URL")
}

model Listing {
  id          String   @id @default(cuid())

  // ── Identity (used for deduplication) ───────────────────────────────────
  url         String   @unique
  source      String   // "craigslist_milwaukee" | "zillow" | "realtor" | etc.

  // ── §3.2 — Core data extraction fields ───────────────────────────────────
  title        String?
  price        Int?
  address      String?
  location     String?
  propertyType String?   // "single_family" | "multi_family" | "duplex" | etc.
  postedDate   DateTime? // listing date
  description  String?

  // ── §3.2 — Property details ───────────────────────────────────────────────
  bedrooms    Int?
  bathrooms   Float?
  squareFeet  Int?

  // ── §3.2 — Owner contact (extracted from post body where available) ───────
  ownerName   String?
  ownerPhone  String?

  // ── §3.3 — Data enrichment (filled by enrichment pipeline) ───────────────
  zestimate        Int?  // Zillow estimate
  realtorEstimate  Int?  // Realtor.com estimate
  redfinEstimate   Int?  // Redfin estimate
  propwireEstimate Int?  // Propwire estimate

  // ── §3.5 — Underwriting ───────────────────────────────────────────────────
  // "good_deal" | "average_deal" | "low_potential" | null (not yet scored)
  dealScore      String?
  equityEstimate Int?    // ARV - price (calculated from best available estimate)

  // ── Meta ──────────────────────────────────────────────────────────────────
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  @@index([source])
  @@index([price])
  @@index([location])
  @@index([dealScore])
  @@index([propertyType])
  @@index([ownerPhone])  // quick lookup for CRM deduplication
}
